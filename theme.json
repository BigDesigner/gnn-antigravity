{
	"version": 2,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"color": {
			"custom": true,
			"customGradient": true,
			"palette": [
				{
					"slug": "primary",
					"color": "#00f2ff",
					"name": "Primary (Accent)"
				},
				{
					"slug": "secondary",
					"color": "#7000ff",
					"name": "Secondary"
				},
				{
					"slug": "background",
					"color": "#000000",
					"name": "Background"
				},
				{
					"slug": "surface",
					"color": "#111111",
					"name": "Surface"
				},
				{
					"slug": "text",
					"color": "#ffffff",
					"name": "Text"
				},
				{
					"slug": "text-muted",
					"color": "#888888",
					"name": "Text Muted"
				},
				{
					"slug": "white",
					"color": "#ffffff",
					"name": "White"
				}
			],
			"gradients": [
				{
					"slug": "primary-gradient",
					"gradient": "linear-gradient(135deg, #00f2ff 0%, #7000ff 100%)",
					"name": "Primary Gradient"
				}
			]
		},
		"typography": {
			"customFontSize": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Inter\", system-ui, -apple-system, sans-serif",
					"name": "Inter",
					"slug": "inter"
				},
				{
					"fontFamily": "\"Outfit\", system-ui, -apple-system, sans-serif",
					"name": "Outfit",
					"slug": "outfit"
				},
				{
					"fontFamily": "\"JetBrains Mono\", monospace",
					"name": "Mono",
					"slug": "mono"
				}
			],
			"fontSizes": [
				{
					"size": "0.75rem",
					"slug": "xs",
					"name": "Extra Small"
				},
				{
					"size": "0.875rem",
					"slug": "small",
					"name": "Small"
				},
				{
					"size": "1rem",
					"slug": "medium",
					"name": "Medium"
				},
				{
					"size": "1.25rem",
					"slug": "large",
					"name": "Large"
				},
				{
					"size": "1.5rem",
					"slug": "xl",
					"name": "Extra Large"
				},
				{
					"size": "clamp(2rem, 5vw, 4rem)",
					"slug": "huge",
					"name": "Huge"
				}
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw" ],
			"blockGap": "1.5rem",
			"spacingScale": {
				"steps": 0
			},
			"spacingSizes": [
				{ "size": "1rem", "slug": "30", "name": "1" },
				{ "size": "1.5rem", "slug": "40", "name": "2" },
				{ "size": "2rem", "slug": "50", "name": "3" },
				{ "size": "3rem", "slug": "60", "name": "4" }
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--inter)",
			"lineHeight": "1.6"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"button": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--background)"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"bottom": "0.75rem",
						"left": "1.5rem",
						"right": "1.5rem"
					}
				},
				"typography": {
					"fontWeight": "600",
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--white)"
					}
				}
			}
		},
		"blocks": {
			"core/heading": {
				"typography": {
					"fontWeight": "700",
					"lineHeight": "1.2"
				}
			}
		}
	}
}